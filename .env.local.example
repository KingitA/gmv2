# =====================================================
# GM ERP — Variables de Entorno
#
# INSTRUCCIONES:
# 1. Copiá este archivo como .env.local
# 2. Completá cada valor con tus credenciales reales
# 3. NUNCA subas .env.local a Git (ya está en .gitignore)
# =====================================================

# ─── Supabase ─────────────────────────────────────────
# URL y clave publica (visibles en el navegador, protegidas por RLS)
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Clave de servicio (SECRETA - solo servidor, bypassa RLS)
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ─── Claude / Anthropic ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-TU_KEY_AQUI

# ─── Google Gemini (OCR de imagenes y PDFs) ──────────
GEMINI_API_KEY=tu_gemini_api_key_aqui

# ─── Google OAuth (para integracion con Gmail) ───────
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret_aqui
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ─── Gmail Push Notifications (Pub/Sub) — opcional ───
# Habilita procesamiento de emails en tiempo real
# Configurar en: https://console.cloud.google.com
GOOGLE_CLOUD_PROJECT_ID=tu_gcp_project_id
GMAIL_PUBSUB_TOPIC=projects/tu_gcp_project_id/topics/gmail-push
GMAIL_WEBHOOK_SECRET=genera_un_secreto_random_aqui

# ─── Automatizacion / Webhooks ───────────────────────
# Clave para recibir pedidos via Make.com/Zapier
AUTOMATION_API_KEY=genera_una_api_key_segura_aqui

# ─── Cron Jobs ───────────────────────────────────────
# Secreto para proteger endpoints de tareas programadas
CRON_SECRET=genera_un_secreto_para_cron_aqui
